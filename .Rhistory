library(readr)
martes <- as.Date ("2026-03-10")
viernes <- as.Date("2026-03-13")
advdate <- function(obj, adv) {
Sys.setlocale("LC_TIME", "es_ES")
tmon <- obj + 7*(adv-1)
tmon <- format(tmon, format="%d/%m")
zadv <- sprintf("%02d", adv)
dia <- weekdays(obj)
tmp <- paste0("Semana ",zadv, ", ", dia,' ', tmon)
return(tmp)
}
getwd()
